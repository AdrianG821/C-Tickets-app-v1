<Page x:Class="TicketsProject.TestersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TicketsProject"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TestersPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Button Click="BackButton"  Content="Back to the list" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="5"/>
            <TextBlock FontSize="22" FontWeight="Bold">Manage testers/devs</TextBlock>

        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <WrapPanel>
                    <TextBlock x:Name="TextContentBlock" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15 0 15 0"/>
                    <TextBox x:Name="NameETextBox" Width="350" MaxLength="150" Padding="5" Text="Name" Tag="Name" GotFocus="RemovePlaceholder" LostFocus="AddPlaceholder"/>
                    <Button Click="AddFunction"  Content="Add" Width="50" Margin="15 0 0 0"/>
                </WrapPanel>
            </StackPanel>

            <ListView Grid.Row="1" x:Name="ListViewClients" ItemsSource="{Binding TestersClass}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" DisplayMemberBinding="{Binding TestersId}"/>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding TestersName}"/>
                        <GridViewColumn Header="Active?" DisplayMemberBinding="{Binding TestersActive}"/>
                        <GridViewColumn Header="Created Date" DisplayMemberBinding="{Binding TestersCreatedAt}"/>
                    </GridView>
                </ListView.View>
            </ListView>


        </Grid>

    </Grid>
</Page>
