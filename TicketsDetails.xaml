<Page x:Class="TicketsProject.TicketsDetails"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TicketsProject"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TicketsDetails"
      FontSize="15">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>


        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock FontSize="22" FontWeight="Bold">Ticket Id <TextBlock Text="{Binding Ticket.TicketsId}"/></TextBlock>
            </StackPanel>
            <Button Click="BackButton" Grid.Column="1" Content="Back to the list" VerticalAlignment="Center" HorizontalAlignment="Left" Padding="5"/>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Title"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleTicketsName" Width="275" MaxLength="50" Text="{Binding Ticket.TicketsName}"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Status"/>
            <ComboBox Grid.Row="0" Grid.Column="3" HorizontalAlignment="Left" x:Name="StatusDropDown" Width="275" ItemsSource="{Binding StatusList}" SelectedValue="{Binding Ticket.TicketsStatus}"/>



            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tester"/>
            <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" x:Name="TesterDropDown" Width="275" ItemsSource="{Binding Testers}" DisplayMemberPath="TestersName" SelectedValuePath="TestersId" SelectedValue="{Binding Ticket.TicketsTester}">
            </ComboBox>


            <TextBlock Grid.Row="1" Grid.Column="2" Text="Priority"/>
            <ComboBox Grid.Row="1" Grid.Column="3" HorizontalAlignment="Left" x:Name="PriorityDropDown" Width="275" ItemsSource="{Binding PriorityList}" SelectedValue="{Binding Ticket.TicketsPriority}"/>


            <TextBlock Grid.Row="2" Grid.Column="0" Text="Developer"/>
            <ComboBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" x:Name="DeveloperDropDown" Width="275" ItemsSource="{Binding Developers}" DisplayMemberPath="DevelopersName" SelectedValuePath="DevelopersId" SelectedValue="{Binding Ticket.TicketsDeveloper}">
            </ComboBox>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Client"/>
            <ComboBox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left" x:Name="ClientsDropDown" Width="275" ItemsSource="{Binding Clients}" DisplayMemberPath="ClientsName" SelectedValuePath="ClientsId" SelectedValue="{Binding Ticket.TicketsClient}">
            </ComboBox>


        </Grid>

        <StackPanel Grid.Row="2" Width="1000" HorizontalAlignment="Left" Margin="0 15 0 0">
            <Button x:Name="InsertTicketBtn" Click="InsertTicket" Content="Create Ticket" Width="250" HorizontalAlignment="Center"/>
            <Button x:Name="UpdateTicketBtn" Click="UpdateCurrentTicket" Content="Update Ticket" Width="250" HorizontalAlignment="Center"/>

        </StackPanel>


        <Grid Grid.Row="3" x:Name="GridCommentsSection">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="NameTextBlock" Text="Comments" FontSize="18" FontWeight="Bold" Margin="0 0 0 10"/>

            <ListBox Grid.Row="1" x:Name="ListBoxComments" ItemsSource="{Binding Comments}" Padding="3" Margin="15" BorderThickness="1" Width="800" HorizontalAlignment="Left">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0 0 0 10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CommentName}" FontWeight="Bold"/>
                                    <TextBlock Text="  -  "/>
                                    <TextBlock Text="{Binding CommentDate}" Foreground="Gray"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" Width="700" Margin="0 5 0 0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        
        <Grid Grid.Row="4" x:Name="GridCommentsInput">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Row="0" Grid.Column="0" x:Name="NameChatTextBox" Margin="10 0 10 10" FontSize="20" MaxLength="25" Text="Name"  Tag="Name" GotFocus="RemovePlaceholder" LostFocus="AddPlaceholder"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="CommentChatTextBox" Margin="10 0 10 10" FontSize="20" MaxLength="100" Text="Comment"  Tag="Comment" GotFocus="RemovePlaceholder" LostFocus="AddPlaceholder"/>
            <Button Grid.Row="0" Click="InsertComments" Grid.Column="2" Content="Add Coment" Margin="10 0 10 10" FontSize="20" />
        </Grid>
    </Grid>
</Page>
